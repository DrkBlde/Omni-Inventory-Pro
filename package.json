{
  "name": "omni-inventory-pro",
  "private": true,
  "version": "2.2.0",
  "description": "Simple Yet Powerful Inventory Management System",
  "author": "Omni Dev Team",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "electron:dev": "concurrently \"npm run dev\" \"electron .\"",
    "dist": "npm run build && electron-builder --win",
    "server": "node server/index.cjs",
    "server:dev": "tsx server/index.ts",
    "db:init": "node server/init-db.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev --name init",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:reset": "node server/reset-db.js",
    "service:install": "node server/windows-service.js install",
    "service:start": "node server/windows-service.js start",
    "service:stop": "node server/windows-service.js stop",
    "service:remove": "node server/windows-service.js remove",
    "autostart:install": "node server/auto-start.js install",
    "autostart:remove": "node server/auto-start.js remove"
  },
  "prisma": {
    "seed": "node server/seed.cjs"
  },
