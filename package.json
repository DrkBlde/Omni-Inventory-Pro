  "build": {
    "appId": "com.omni.inventory.pro",
    "productName": "Omni Inventory Pro",
    "buildVersion": "2.2.0.0",
    "asar": true,
    "directories": {
      "output": "dist_msi"
    },
    "win": {
      "target": [
        "msi"
      ],
      "icon": "public/icon.ico"
    },
    "msi": {
      "oneClick": false,
      "perMachine": true,
      "runAfterFinish": true,
      "shortcutName": "Omni Inventory Pro",
      "warningsAsErrors": false
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
